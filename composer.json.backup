{
    "name": "ai/context-system",
    "description": "128K AI Context Management System with Multi-Provider Support",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "AI Context Team",
            "email": "dev@ahhada.com"
        }
    ],
    "require": {
        "php": ">=8.4.0",
        "ext-curl": "*",
        "ext-filter": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "ext-pgsql": "*",
        "ext-session": "*",
        "brick/math": "^0.12.1",
        "firebase/php-jwt": "^7.0",
        "guzzlehttp/guzzle": "^7.9",
        "illuminate/database": "^11.28",
        "illuminate/events": "^11.28",
        "illuminate/pagination": "^11.28",
        "monolog/monolog": "^3.6",
        "nesbot/carbon": "^3.8",
        "psr/container": "^2.0",
        "psr/http-client": "^1.0",
        "psr/http-message": "^2.0",
        "psr/log": "^3.0",
        "ramsey/uuid": "^4.7",
        "symfony/polyfill-mbstring": "^1.29",
        "symfony/var-dumper": "^7.1",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "mockery/mockery": "^1.6",
        "fakerphp/faker": "^1.23"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "src/helpers.php",
            "src/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php -r \"file_exists('database') || mkdir('database', 0755, true);\"",
            "@php -r \"file_exists('storage') || mkdir('storage', 0755, true);\"",
            "@php -r \"file_exists('storage/logs') || mkdir('storage/logs', 0755, true);\""
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php -r \"file_exists('storage') || mkdir('storage', 0755, true);\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage",
        "analyse": "phpstan analyse",
        "lint": "php-cs-fixer fix --dry-run",
        "fix": "php-cs-fixer fix",
        "serve": "php -S localhost:8000 -t public",
        "deploy": [
            "composer install --no-dev --optimize-autoloader",
            "php artisan optimize:clear",
            "php artisan optimize"
        ],
        "health": "php src/Commands/HealthCheck.php",
        "migrate": "php src/Commands/Migrate.php",
        "seed": "php src/Commands/Seed.php"
    },
    "scripts-descriptions": {
        "test": "Run PHPUnit tests",
        "deploy": "Deployment script",
        "health": "Run system health check",
        "migrate": "Run database migrations",
        "seed": "Run database seeders"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "platform-check": false,
        "process-timeout": 600,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "composer",
            "url": "https://repo.packagist.org"
        }
    ]
}
